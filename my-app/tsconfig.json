{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "node16",
    "customConditions": [
      "react-native"
    ],
    "jsx": "react-native",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@components/*": [
        "components/*"
      ],
      "@hooks/*": [
        "hooks/*"
      ],
      "@constants/*": [
        "constants/*"
      ]
    },
    "allowJs": false
  },
  "exclude": [
    "node_modules",
    "scripts",
    "**/*.config.js",
    "**/*.js"
  ],
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
